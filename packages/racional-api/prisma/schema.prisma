generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Mirrors Supabase auth.users — we own this row, Supabase owns identity
model User {
  id         String   @id
  full_name  String
  phone      String?
  email      String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  portfolios      Portfolio[]
  transactions    Transaction[]
  watchlistItems  WatchlistItem[]

  @@map("users")
}

model Portfolio {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  description String?
  currency    String   @default("USD")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user     User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  orders   Order[]
  holdings PortfolioHolding[]

  @@index([user_id])
  @@map("portfolios")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

// Wallet movements — linked to the user, not to any portfolio
model Transaction {
  id          String          @id @default(uuid())
  user_id     String
  type        TransactionType
  amount      Decimal         @db.Decimal(18, 6)
  date        DateTime
  description String?
  created_at  DateTime        @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, date(sort: Desc)])
  @@map("transactions")
}

model Stock {
  id       String  @id @default(uuid())
  ticker   String  @unique
  name     String
  exchange String?
  currency String  @default("USD")

  orders   Order[]
  holdings PortfolioHolding[]

  @@map("stocks")
}

enum OrderType {
  BUY
  SELL
}

model Order {
  id             String    @id @default(uuid())
  portfolio_id   String
  stock_id       String
  type           OrderType
  quantity       Decimal   @db.Decimal(18, 6)
  price_per_unit Decimal   @db.Decimal(18, 6)
  total_amount   Decimal   @db.Decimal(18, 6)
  date           DateTime
  created_at     DateTime  @default(now())

  portfolio Portfolio @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  stock     Stock     @relation(fields: [stock_id], references: [id])

  @@index([portfolio_id, date(sort: Desc)])
  @@map("orders")
}

model WatchlistItem {
  id           String   @id @default(uuid())
  user_id      String
  ticker       String
  notes        String?
  target_price Decimal? @db.Decimal(18, 6)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, ticker])
  @@index([user_id])
  @@map("watchlist_items")
}

// Denormalized cache of current holdings — updated atomically with each Order insert
model PortfolioHolding {
  id           String  @id @default(uuid())
  portfolio_id String
  stock_id     String
  quantity     Decimal @db.Decimal(18, 6)
  average_cost Decimal @db.Decimal(18, 6)

  portfolio Portfolio @relation(fields: [portfolio_id], references: [id], onDelete: Cascade)
  stock     Stock     @relation(fields: [stock_id], references: [id])

  @@unique([portfolio_id, stock_id])
  @@index([portfolio_id])
  @@map("portfolio_holdings")
}
